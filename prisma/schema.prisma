generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      String   @default("TEACHER") // PRINCIPAL | ADMIN | TEACHER | ACCOUNTS
  classId   String?  // legacy — kept for compatibility
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class               Class?               @relation(fields: [classId], references: [id])
  attendanceSubmitted Attendance[]
  assignments         TeacherAssignment[]  @relation("TeacherAssignments")
  homeworkCreated     Homework[]
  lessonPlans         LessonPlan[]
  announcements       Announcement[]
  leaveApplications   TeacherLeave[]       @relation("TeacherLeaves")
  substituteFor       TeacherLeave[]       @relation("SubstituteLeaves")
  studyMaterials      StudyMaterial[]
  ptmSlots            PTMSlot[]
  behaviourRemarks    BehaviourRemark[]
  salaryRecords       SalaryRecord[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Class {
  id       String @id @default(cuid())
  name     String @unique
  order    Int    @unique

  sections          Section[]
  teachers          User[]
  feeStructures     FeeStructure[]
  exams             Exam[]
  teacherAssignments TeacherAssignment[]
  homework          Homework[]
  lessonPlans       LessonPlan[]
  announcements     Announcement[]
  ptmSlots          PTMSlot[]
}

model Section {
  id       String    @id @default(cuid())
  name     String
  classId  String
  class    Class     @relation(fields: [classId], references: [id])
  students Student[]
  attendances Attendance[]

  @@unique([classId, name])
}

model Student {
  id            String   @id @default(cuid())
  rollNo        String
  name          String
  dateOfBirth   DateTime?
  gender        String?
  fatherName    String?
  motherName    String?
  phone         String?
  address       String?
  photoUrl      String?
  admissionNo   String?  @unique
  admissionYear Int      @default(2024)
  sectionId     String
  status        String   @default("ACTIVE") // ACTIVE | PASSED_OUT | LEFT | ARCHIVED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section              Section           @relation(fields: [sectionId], references: [id])
  attendanceRecords    AttendanceRecord[]
  marksEntries         MarksEntry[]
  feePayments          FeePayment[]
  behaviourRemarks     BehaviourRemark[]
  homeworkSubmissions  HomeworkSubmission[]
  ptmSlots             PTMSlot[]
  feeWaivers           FeeWaiver[]
  libraryIssues        LibraryIssue[]

  @@unique([sectionId, rollNo])
}

model Attendance {
  id          String   @id @default(cuid())
  date        String   // "YYYY-MM-DD"
  sectionId   String
  submittedBy String
  submittedAt DateTime @default(now())
  isLocked    Boolean  @default(false)

  section  Section @relation(fields: [sectionId], references: [id])
  teacher  User    @relation(fields: [submittedBy], references: [id])
  records  AttendanceRecord[]

  @@unique([date, sectionId])
}

model AttendanceRecord {
  id           String @id @default(cuid())
  attendanceId String
  studentId    String
  status       String @default("PRESENT") // PRESENT | ABSENT | LATE | HALF_DAY

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([attendanceId, studentId])
}

model Subject {
  id       String  @id @default(cuid())
  name     String
  code     String?
  maxMarks Int     @default(100)
  classId  String?

  marksEntries       MarksEntry[]
  teacherAssignments TeacherAssignment[]
  homework           Homework[]
  lessonPlans        LessonPlan[]
  studyMaterials     StudyMaterial[]
}

model Exam {
  id        String   @id @default(cuid())
  name      String
  classId   String?
  year      Int
  startDate DateTime?
  endDate   DateTime?

  class        Class?       @relation(fields: [classId], references: [id])
  marksEntries MarksEntry[]
}

model MarksEntry {
  id        String  @id @default(cuid())
  studentId String
  examId    String
  subjectId String
  marks     Float?
  isAbsent  Boolean @default(false)
  remarks   String?

  student Student @relation(fields: [studentId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examId, subjectId])
}

model FeeStructure {
  id           String   @id @default(cuid())
  classId      String
  feeType      String
  amount       Float
  dueDate      DateTime?
  academicYear String
  createdAt    DateTime @default(now())

  class    Class        @relation(fields: [classId], references: [id])
  payments FeePayment[]

  @@unique([classId, feeType, academicYear])
}

model FeePayment {
  id             String   @id @default(cuid())
  studentId      String
  feeStructureId String?
  amount         Float
  paymentDate    DateTime @default(now())
  mode           String   @default("CASH") // CASH | ONLINE | CHEQUE
  receiptNo      String   @unique
  remarks        String?
  isWaived       Boolean  @default(false)
  lateFine       Float    @default(0)
  createdAt      DateTime @default(now())

  student      Student       @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  createdAt   DateTime @default(now())

  images Gallery[]
}

model Gallery {
  id       String @id @default(cuid())
  albumId  String
  imageUrl String
  caption  String?
  order    Int    @default(0)

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model Circular {
  id          String   @id @default(cuid())
  title       String
  fileUrl     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SchoolEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SchoolSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ─── Teacher Portal Models ────────────────────────────────────────────────────

model TeacherAssignment {
  id             String  @id @default(cuid())
  teacherId      String
  classId        String
  subjectId      String?  // null means class teacher (no specific subject)
  isClassTeacher Boolean @default(false)
  academicYear   String  @default("2025-26")
  createdAt      DateTime @default(now())

  teacher  User     @relation("TeacherAssignments", fields: [teacherId], references: [id])
  class    Class    @relation(fields: [classId], references: [id])
  subject  Subject? @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId, academicYear])
}

model BehaviourRemark {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  remark    String
  type      String   @default("GENERAL") // GENERAL | POSITIVE | NEGATIVE | CONDUCT
  date      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  teacher User    @relation(fields: [teacherId], references: [id])
}

model Homework {
  id          String   @id @default(cuid())
  title       String
  description String?
  classId     String
  subjectId   String
  teacherId   String
  dueDate     DateTime
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacher     User     @relation(fields: [teacherId], references: [id])
  submissions HomeworkSubmission[]
}

model HomeworkSubmission {
  id          String    @id @default(cuid())
  homeworkId  String
  studentId   String
  status      String    @default("PENDING") // PENDING | SUBMITTED | GRADED
  marks       Float?
  remarks     String?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
}

model LessonPlan {
  id          String   @id @default(cuid())
  teacherId   String
  classId     String
  subjectId   String
  topic       String
  description String?
  date        DateTime
  duration    Int?     // minutes
  status      String   @default("PLANNED") // PLANNED | COMPLETED | SKIPPED
  createdAt   DateTime @default(now())

  teacher User    @relation(fields: [teacherId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  scope     String   @default("CLASS") // CLASS | SCHOOL_WIDE
  classId   String?
  createdAt DateTime @default(now())

  author User   @relation(fields: [authorId], references: [id])
  class  Class? @relation(fields: [classId], references: [id])
}

model TeacherLeave {
  id           String    @id @default(cuid())
  teacherId    String
  fromDate     DateTime
  toDate       DateTime
  reason       String
  leaveType    String    @default("CASUAL") // CASUAL | SICK | EARNED
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  substituteId String?
  appliedAt    DateTime  @default(now())
  reviewedBy   String?
  reviewedAt   DateTime?
  remarks      String?

  teacher    User  @relation("TeacherLeaves", fields: [teacherId], references: [id])
  substitute User? @relation("SubstituteLeaves", fields: [substituteId], references: [id])
}

model StudyMaterial {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  classId     String?
  subjectId   String?
  teacherId   String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  teacher  User     @relation(fields: [teacherId], references: [id])
  subject  Subject? @relation(fields: [subjectId], references: [id])
}

model PTMSlot {
  id          String   @id @default(cuid())
  classId     String
  teacherId   String
  date        DateTime
  startTime   String   // "HH:MM"
  duration    Int      @default(15) // minutes
  parentName  String?
  studentId   String?
  status      String   @default("AVAILABLE") // AVAILABLE | BOOKED | COMPLETED
  notes       String?
  createdAt   DateTime @default(now())

  class   Class    @relation(fields: [classId], references: [id])
  teacher User     @relation(fields: [teacherId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])
}

// ─── Accounts & Operations Models ────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("OTHER") // UTILITIES | MAINTENANCE | SUPPLIES | PETTY_CASH | TRANSPORT | SALARIES | OTHER
  amount      Float
  date        DateTime
  description String?
  vendorName  String?
  invoiceNo   String?
  paymentMode String   @default("CASH") // CASH | ONLINE | BANK_TRANSFER
  createdBy   String
  createdAt   DateTime @default(now())
}

model SalaryRecord {
  id          String    @id @default(cuid())
  teacherId   String
  month       Int       // 1-12
  year        Int
  basicSalary Float
  allowances  Float     @default(0)
  deductions  Float     @default(0)
  netSalary   Float
  paymentDate DateTime?
  status      String    @default("PENDING") // PENDING | PAID
  remarks     String?
  createdAt   DateTime  @default(now())

  teacher User @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, month, year])
}

model FeeWaiver {
  id          String    @id @default(cuid())
  studentId   String
  amount      Float
  reason      String
  type        String    @default("DISCOUNT") // DISCOUNT | SCHOLARSHIP | SIBLING | STAFF_WARD | OTHER
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  requestedBy String
  approvedBy  String?
  approvedAt  DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model LibraryBook {
  id              String   @id @default(cuid())
  title           String
  author          String?
  isbn            String?  @unique
  subject         String?
  publisher       String?
  edition         String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  createdAt       DateTime @default(now())

  issues LibraryIssue[]
}

model LibraryIssue {
  id         String    @id @default(cuid())
  bookId     String
  studentId  String?
  issuedTo   String
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float     @default(0)
  status     String    @default("ISSUED") // ISSUED | RETURNED | OVERDUE

  book    LibraryBook @relation(fields: [bookId], references: [id])
  student Student?    @relation(fields: [studentId], references: [id])
}

model Complaint {
  id              String   @id @default(cuid())
  complainantName String
  complainantType String   @default("PARENT") // PARENT | STUDENT | STAFF | OTHER
  phone           String?
  category        String   @default("OTHER") // ACADEMIC | FACILITY | STAFF | TRANSPORT | OTHER
  description     String
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | ESCALATED
  assignedTo      String?
  resolution      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BusRoute {
  id          String   @id @default(cuid())
  routeName   String   @unique
  origin      String
  destination String
  stops       String
  driverName  String?
  driverPhone String?
  vehicleNo   String?
  fee         Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
