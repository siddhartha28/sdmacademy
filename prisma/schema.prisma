generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      String   @default("TEACHER") // PRINCIPAL | ADMIN | TEACHER
  classId   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class               Class?               @relation(fields: [classId], references: [id])
  attendanceSubmitted Attendance[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   @unique
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Class {
  id       String @id @default(cuid())
  name     String @unique
  order    Int    @unique
  sections Section[]
  teachers User[]
  feeStructures FeeStructure[]
  exams    Exam[]
}

model Section {
  id       String    @id @default(cuid())
  name     String
  classId  String
  class    Class     @relation(fields: [classId], references: [id])
  students Student[]
  attendances Attendance[]

  @@unique([classId, name])
}

model Student {
  id            String   @id @default(cuid())
  rollNo        String
  name          String
  dateOfBirth   DateTime?
  gender        String?
  fatherName    String?
  motherName    String?
  phone         String?
  address       String?
  photoUrl      String?
  admissionNo   String?  @unique
  admissionYear Int      @default(2024)
  sectionId     String
  status        String   @default("ACTIVE") // ACTIVE | PASSED_OUT | LEFT | ARCHIVED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section           Section          @relation(fields: [sectionId], references: [id])
  attendanceRecords AttendanceRecord[]
  marksEntries      MarksEntry[]
  feePayments       FeePayment[]

  @@unique([sectionId, rollNo])
}

model Attendance {
  id          String   @id @default(cuid())
  date        String   // "YYYY-MM-DD"
  sectionId   String
  submittedBy String
  submittedAt DateTime @default(now())
  isLocked    Boolean  @default(false)

  section  Section @relation(fields: [sectionId], references: [id])
  teacher  User    @relation(fields: [submittedBy], references: [id])
  records  AttendanceRecord[]

  @@unique([date, sectionId])
}

model AttendanceRecord {
  id           String @id @default(cuid())
  attendanceId String
  studentId    String
  status       String @default("PRESENT") // PRESENT | ABSENT | LATE | HALF_DAY

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([attendanceId, studentId])
}

model Subject {
  id       String @id @default(cuid())
  name     String
  code     String?
  maxMarks Int    @default(100)
  classId  String?

  marksEntries MarksEntry[]
}

model Exam {
  id        String   @id @default(cuid())
  name      String
  classId   String?
  year      Int
  startDate DateTime?
  endDate   DateTime?

  class        Class?       @relation(fields: [classId], references: [id])
  marksEntries MarksEntry[]
}

model MarksEntry {
  id        String  @id @default(cuid())
  studentId String
  examId    String
  subjectId String
  marks     Float?
  isAbsent  Boolean @default(false)
  remarks   String?

  student Student @relation(fields: [studentId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examId, subjectId])
}

model FeeStructure {
  id           String   @id @default(cuid())
  classId      String
  feeType      String
  amount       Float
  dueDate      DateTime?
  academicYear String
  createdAt    DateTime @default(now())

  class    Class        @relation(fields: [classId], references: [id])
  payments FeePayment[]

  @@unique([classId, feeType, academicYear])
}

model FeePayment {
  id             String   @id @default(cuid())
  studentId      String
  feeStructureId String?
  amount         Float
  paymentDate    DateTime @default(now())
  mode           String   @default("CASH") // CASH | ONLINE | CHEQUE
  receiptNo      String   @unique
  remarks        String?
  isWaived       Boolean  @default(false)
  lateFine       Float    @default(0)
  createdAt      DateTime @default(now())

  student      Student       @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  createdAt   DateTime @default(now())

  images Gallery[]
}

model Gallery {
  id       String @id @default(cuid())
  albumId  String
  imageUrl String
  caption  String?
  order    Int    @default(0)

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model Circular {
  id          String   @id @default(cuid())
  title       String
  fileUrl     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SchoolEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SchoolSettings {
  id           String  @id @default(cuid())
  key          String  @unique
  value        String
}
